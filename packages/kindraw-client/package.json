{
  "name": "@kindraw/client",
  "version": "0.1.0",
  "description": "Node client for the Kindraw public API (HTTP) + optional Mermaid→Excalidraw generation. Shared by the Kindraw CLI and MCP server.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./generate": {
      "types": "./dist/generate.d.ts",
      "default": "./dist/generate.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ./build.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "canvas": "^3.0.0",
    "jsdom": "^24.0.0"
  },
  "devDependencies": {
    "@types/jsdom": "28.0.3",
    "esbuild": "^0.21.0"
  }
}
